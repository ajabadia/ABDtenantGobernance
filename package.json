  "private": true,
  "scripts": {
    "dev": "next dev -p 5002 --webpack",
    "prebuild": "node ./scripts/clean-quiz.js",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "full-audit": "powershell -File ./scripts/abd-audit.ps1",
